# 2. SỬA DÒNG NÀY: Trỏ về chính Docker Backend đang chạy trên máy Hải
VITE_NOTIFY_API=http://192.168.24.34:5066

# 3. Khi không dùng gateway, để trống prefix để FE gọi trực tiếp tới backend
